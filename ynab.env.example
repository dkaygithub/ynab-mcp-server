# Copy this file to data/ynab.env and fill in your real values.
# data/ynab.env is gitignored so the token never gets committed.
#
# Get a Personal Access Token at: YNAB > Account Settings > Developer Settings > New Token

YNAB_API_TOKEN=your_personal_access_token_here

# Optional: pin a default budget so tools don't need budgetId every call.
# Find it in the YNAB web app URL: app.ynab.com/<THIS-IS-YOUR-BUDGET-ID>/budget
# YNAB_BUDGET_ID=
